# Copied from tests/.coveragerc to .coveragerc on github actions

[run]
omit =
    */__init__.py
    */_version.py
    # */behavior/*
    */cli/*
    # */common/*
    */data_import/*
    */decoding/v0/*
    # */decoding/*
    # */lfp/*
    # */linearization/*
    */lock/*
    */mua/*
    # Include position v2 for coverage - exclude only legacy v1 utils
    */position/v1/*
    */position/utils/make_video.py
    */position/utils/tool_strategies.py
    */ripple/*
    */sharing/*
    # */spikesorting/*
    # */utils/*
    settings.py

[report]
exclude_lines =
    pragma: no cover
    if.*test_mode
    if __name__ == .__main__.:
    raise NotImplementedError
    pass

# Show missing lines to help identify uncovered code
show_missing = True
