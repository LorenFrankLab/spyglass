# Spike sorting v2 baseline artifacts: commit only the small .pkl/.json baselines.
!tests/spikesorting/v2/baselines/*.json
temp_nwb/*s

*.mp4
*.png
*.npy
*.nc
*.csv
*.pkl
*.json
# Spike sorting v2 baseline pickles are small committed reference artifacts;
# this must live after the blanket *.pkl ignore above.
!tests/spikesorting/v2/baselines/*.pkl
# Tracked baseline snapshot for test_no_legacy_schema_changes; must be
# committed despite the blanket *.json ignore so CI's fresh checkout has it.
!tests/spikesorting/v2/baselines/legacy_schemas.json
# Fixture provenance manifest: the pytest-v2 "smoke fixture did not drift"
# step reads it via `git show HEAD:...` to compare deterministic hashes, so it
# must be committed despite the blanket *.json ignore.
!tests/spikesorting/v2/fixtures/fixtures_manifest.json
*.gz
*.pdf
*.lock
*.npz
*.xz
*.zip
*.pb
*.pem
dj_local_conf*
